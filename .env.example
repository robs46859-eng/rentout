# RentOut configuration
PORT=3847
HOST=127.0.0.1
DATABASE_URL=
PGSSL=false
SQLITE_PATH=
SESSION_TTL_DAYS=14
MFA_ISSUER=RentOut
MFA_CHALLENGE_TTL_MINUTES=10
OPERATOR_BOOTSTRAP_EMAIL=
OPERATOR_BOOTSTRAP_PASSWORD=
OPERATOR_BOOTSTRAP_NAME=Platform Admin

# Optional: RentCast API (https://www.rentcast.io/) — market rent & property comps
RENTCAST_API_KEY=

# Optional: ATTOM / CoreLogic style keys if you swap providers in services/market.js
EXTERNAL_REAL_ESTATE_PROVIDER=rentcast

# Census Bureau API key is optional for many ACS endpoints (higher rate limits with key)
CENSUS_API_KEY=

# Default geo for demographic & market pulls (Denver CBSA example)
MARKET_ZIP=80202
MARKET_STATE_FIPS=08
MARKET_PLACE=20000
DEMO_RADIUS_MILES=3

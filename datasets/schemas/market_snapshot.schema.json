{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RentOut Market Snapshot",
  "type": "object",
  "required": ["market_snapshots"],
  "properties": {
    "market_snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "submarket_id",
          "submarket_label",
          "market_avg_rent",
          "occupancy_avg_pct",
          "market_heat_score",
          "source",
          "_meta"
        ],
        "properties": {
          "submarket_id": { "type": "string" },
          "submarket_label": { "type": ["string", "null"] },
          "market_avg_rent": { "type": ["number", "null"] },
          "occupancy_avg_pct": { "type": ["number", "null"] },
          "market_heat_score": { "type": ["number", "null"] },
          "source": { "type": "string" },
          "_meta": {
            "type": "object",
            "required": [
              "source_url",
              "source_title",
              "source_date",
              "evidence",
              "confidence"
            ],
            "properties": {
              "source_url": { "type": "string" },
              "source_title": { "type": "string" },
              "source_date": { "type": ["string", "null"] },
              "evidence": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RentOut SEO Channel Record",
  "type": "object",
  "required": ["seo_channels"],
  "properties": {
    "seo_channels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "channel_name",
          "local_seo_score",
          "distribution_pct",
          "listing_completeness",
          "keyword_clusters",
          "_meta"
        ],
        "properties": {
          "channel_name": { "type": "string" },
          "local_seo_score": { "type": ["number", "null"] },
          "distribution_pct": { "type": ["number", "null"] },
          "listing_completeness": { "type": ["number", "null"] },
          "keyword_clusters": {
            "type": "array",
            "items": { "type": "string" }
          },
          "_meta": {
            "type": "object",
            "required": [
              "source_url",
              "source_title",
              "source_date",
              "evidence",
              "confidence"
            ],
            "properties": {
              "source_url": { "type": "string" },
              "source_title": { "type": "string" },
              "source_date": { "type": ["string", "null"] },
              "evidence": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

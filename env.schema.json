{
  "project": "rentout",
  "service": {
    "renderServiceName": "rentout-app"
  },
  "environments": {
    "local": {
      "description": "Developer machine using SQLite by default"
    },
    "staging": {
      "description": "Render staging with Postgres and live upstream integrations"
    },
    "production": {
      "description": "Render production"
    }
  },
  "variables": {
    "PORT": {
      "kind": "config",
      "description": "HTTP port for the service",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "3847",
        "staging": "10000",
        "production": "10000"
      },
      "renderSync": true
    },
    "HOST": {
      "kind": "config",
      "description": "Bind host",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "127.0.0.1",
        "staging": "0.0.0.0",
        "production": "0.0.0.0"
      },
      "renderSync": true
    },
    "DATABASE_URL": {
      "kind": "secret",
      "description": "Primary Postgres connection string",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "PGSSL": {
      "kind": "config",
      "description": "Whether to require SSL for Postgres",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "false",
        "staging": "false",
        "production": "false"
      },
      "allowedValues": ["true", "false"],
      "renderSync": true
    },
    "SQLITE_PATH": {
      "kind": "config",
      "description": "Optional SQLite file path for local runtime",
      "requiredIn": [],
      "renderSync": false
    },
    "SESSION_TTL_DAYS": {
      "kind": "config",
      "description": "Session lifetime in days",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "14",
        "staging": "14",
        "production": "14"
      },
      "renderSync": true
    },
    "MFA_ISSUER": {
      "kind": "config",
      "description": "Authenticator issuer label",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "RentOut",
        "staging": "RentOut",
        "production": "RentOut"
      },
      "renderSync": true
    },
    "MFA_CHALLENGE_TTL_MINUTES": {
      "kind": "config",
      "description": "MFA challenge lifetime in minutes",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "10",
        "staging": "10",
        "production": "10"
      },
      "renderSync": true
    },
    "OPERATOR_BOOTSTRAP_EMAIL": {
      "kind": "secret",
      "description": "Bootstrap admin email for first service startup",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "OPERATOR_BOOTSTRAP_PASSWORD": {
      "kind": "secret",
      "description": "Bootstrap admin password for first service startup",
      "requiredIn": ["staging", "production"],
      "minLength": 12,
      "renderSync": true
    },
    "OPERATOR_BOOTSTRAP_NAME": {
      "kind": "config",
      "description": "Bootstrap admin display name",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "Platform Admin",
        "staging": "Platform Admin",
        "production": "Platform Admin"
      },
      "renderSync": true
    },
    "RENTCAST_API_KEY": {
      "kind": "secret",
      "description": "Optional market analytics API key",
      "requiredIn": [],
      "renderSync": true
    },
    "EXTERNAL_REAL_ESTATE_PROVIDER": {
      "kind": "config",
      "description": "Market analytics provider identifier",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "rentcast",
        "staging": "rentcast",
        "production": "rentcast"
      },
      "renderSync": false
    },
    "CENSUS_API_KEY": {
      "kind": "secret",
      "description": "Optional Census API key",
      "requiredIn": [],
      "renderSync": true
    },
    "BUILDIUM_BASE_URL": {
      "kind": "config",
      "description": "Buildium API base URL",
      "requiredIn": ["staging", "production"],
      "defaults": {
        "staging": "https://api.buildium.com",
        "production": "https://api.buildium.com"
      },
      "renderSync": true
    },
    "BUILDIUM_CLIENT_ID": {
      "kind": "secret",
      "description": "Buildium API client ID",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "BUILDIUM_CLIENT_SECRET": {
      "kind": "secret",
      "description": "Buildium API client secret",
      "requiredIn": ["staging", "production"],
      "renderSync": true
    },
    "MARKET_ZIP": {
      "kind": "config",
      "description": "ZIP for market lookups",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "80202",
        "staging": "80202",
        "production": "80202"
      },
      "renderSync": true
    },
    "MARKET_STATE_FIPS": {
      "kind": "config",
      "description": "Census state FIPS code",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "08",
        "staging": "08",
        "production": "08"
      },
      "renderSync": true
    },
    "MARKET_PLACE": {
      "kind": "config",
      "description": "Census place code",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "20000",
        "staging": "20000",
        "production": "20000"
      },
      "renderSync": true
    },
    "DEMO_RADIUS_MILES": {
      "kind": "config",
      "description": "Displayed demographic radius",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "3",
        "staging": "3",
        "production": "3"
      },
      "renderSync": true
    }
  }
}
